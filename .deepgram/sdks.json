      "run_command": "dotnet run",
      "test_command": "dotnet test",
      "package_manager": "nuget",
      "sdk_package": "Deepgram",
      "sdk_import": "using Deepgram;"
    },
    {
      "name": "Java SDK",
      "language": "java",
      "slug": "java",
      "repo": "deepgram/deepgram-java-sdk",
      "file_extension": "java",
      "test_file": "ExampleTest.java",
      "install_command": "mvn install -DskipTests",
