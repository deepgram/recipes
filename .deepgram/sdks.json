{
  "sdks": [
    {
      "name": "Python SDK",
      "language": "python",
      "slug": "python",
      "repo": "deepgram/deepgram-python-sdk",
      "file_extension": "py",
      "test_file": "example_test.py",
      "install_command": "pip install -r requirements.txt",
      "run_command": "python example.py",
      "test_command": "pytest example_test.py -v --timeout=60",
      "package_manager": "pip",
      "sdk_package": "deepgram-sdk",
      "sdk_import": "from deepgram import DeepgramClient"
    },
    {
      "name": "JavaScript SDK",
      "language": "javascript",
      "slug": "javascript",
      "repo": "deepgram/deepgram-js-sdk",
      "file_extension": "js",
      "test_file": "example.test.js",
      "install_command": "npm install",
      "run_command": "node example.js",
      "test_command": "node --test example.test.js",
      "package_manager": "npm",
      "sdk_package": "@deepgram/sdk",
      "sdk_import": "import { createClient } from \"@deepgram/sdk\";"
    },
    {
      "name": "Go SDK",
      "language": "go",
      "slug": "go",
      "repo": "deepgram/deepgram-go-sdk",
      "file_extension": "go",
      "test_file": "example_test.go",
      "install_command": "go mod download",
      "run_command": "go run example.go",
      "test_command": "go test ./... -v -timeout 60s",
      "package_manager": "go",
      "sdk_package": "github.com/deepgram/deepgram-go-sdk/v3",
      "sdk_import": "import \"github.com/deepgram/deepgram-go-sdk/v3\""
    },
    {
      "name": ".NET SDK",
      "language": "dotnet",
